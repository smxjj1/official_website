# Analytics API Token (get from analytics service provider)
NUXT_PUBLIC_ANALYTICS_TOKEN=

# 站点公开 URL（canonical / OG，勿带末尾 /）—与生产一致
NUXT_PUBLIC_SITE_URL=https://oyababies.com

# 与生产一致：统计 API 根地址（勿带末尾 /api）
NUXT_PUBLIC_ANALYTICS_BASE_URL=https://analytics.oyababies.com

# 埋点 siteKey，须与 analytics 平台 websites.site_key 一致（生产同为 oyababies.com）
NUXT_PUBLIC_ANALYTICS_SITE_ID=oyababies.com
