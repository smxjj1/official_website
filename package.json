    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@nuxt/eslint": "1.10.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "less": "^4.6.3",
    "tailwindcss": "^4.1.17"
  }
}
