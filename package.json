{
  "name": "nuxt4-template",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "nuxt start",
    "build": "nuxt build --dotenv .env.production",
    "build:local": "nuxt build --dotenv .env.local",
    "build:dev": "nuxt build --dotenv .env.development",
    "dev": "nuxt dev --dotenv .env.development",
    "dev:local": "nuxt dev --dotenv .env.local",
    "dev:prod": "nuxt dev --dotenv .env.production",
    "generate": "nuxt generate",
    "preview": "nuxt preview --dotenv .env.production",
    "preview:local": "nuxt preview --dotenv .env.local",
    "preview:dev": "nuxt preview --dotenv .env.development",
    "postinstall": "nuxt prepare",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "dependencies": {
    "@nuxt/image": "2.0.0",
    "@pinia/nuxt": "0.11.3",
    "@tailwindcss/typography": "^0.5.19",
